# Firebase Client SDK (used by Vite frontend)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Cerebras API key for LLM inference
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Firebase Admin service account (RAW JSON string, NOT a file path)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate new private key
# Copy the ENTIRE file contents (including { and }) as a single line
# NEVER commit this to git — it stays in .env only
FIREBASE_SERVICE_ACCOUNT_PATH={"type":"service_account","project_id":"..."}
